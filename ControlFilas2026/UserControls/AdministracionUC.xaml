<UserControl x:Class="ControlFilas2026.UserControls.AdministracionUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ControlFilas2026.UserControls"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BrushBackground}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <TextBlock Text="Administración" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrushPrimary}" Margin="0,0,0,16"/>
                
                <!-- CAJAS SECTION -->
                <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Gestión de Cajas" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource BrushPrimary}" Margin="0,0,0,12"/>
                        
                        <TextBlock Text="Seleccionar Caja" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,6"/>
                        <ComboBox x:Name="BoxComboBox" Height="38" Padding="10" FontSize="13" Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" Margin="0,0,0,14"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="✓ Habilitar" Style="{DynamicResource ButtonSuccess}" Height="38" Margin="0,0,6,0" Name="EnableBoxButton"/>
                            <Button Grid.Column="1" Content="✕ Deshabilitar" Style="{DynamicResource ButtonWarning}" Height="38" Margin="6,0,0,0" Name="DisableBoxButton"/>
                        </Grid>
                        
                        <TextBlock Text="Operaciones Globales" FontSize="12" Foreground="{DynamicResource BrushSecondary}" FontWeight="Bold" Margin="0,14,0,10"/>
                        <Button Content="✓✓ Habilitar Todas" Style="{DynamicResource ButtonSuccess}" Height="38" Margin="0" Name="EnableAllButton"/>
                    </StackPanel>
                </Border>
                
                <!-- QUEUE SECTION -->
                <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Control de Fila" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource BrushPrimary}" Margin="0,0,0,12"/>
                        <Button Content="▶ Iniciar" Style="{DynamicResource ButtonSuccess}" Height="38" Margin="0,0,0,10" Name="StartQueueButton"/>
                        <Button Content="⟲ Reiniciar" Style="{DynamicResource ButtonWarning}" Height="38" Margin="0" Name="RestartQueueButton"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
