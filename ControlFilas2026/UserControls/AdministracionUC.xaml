<UserControl x:Class="ControlFilas2026.UserControls.AdministracionUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ControlFilas2026.UserControls"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BrushBackground}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <TextBlock Text="Administración" Style="{DynamicResource SubHeaderText}" Margin="0,0,0,16"/>

                <Border Style="{DynamicResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Gestión de Cajas" Style="{DynamicResource BodyText}" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <TextBlock Text="Caja" Style="{DynamicResource CaptionText}" Margin="0,0,0,6"/>
                        <ComboBox x:Name="BoxComboBox" Height="38" Margin="0,0,0,12"/>

                        <Button x:Name="EnableBoxButton"
                                Content="Habilitar Caja"
                                Style="{DynamicResource ButtonSuccess}"
                                Height="40"
                                HorizontalContentAlignment="Center"
                                Margin="0,0,0,8"/>

                        <Button x:Name="DisableBoxButton"
                                Content="Deshabilitar Caja"
                                Style="{DynamicResource ButtonWarning}"
                                Height="40"
                                HorizontalContentAlignment="Center"
                                Margin="0,0,0,8"/>

                        <Button x:Name="EnableAllButton"
                                Content="Habilitar Todas"
                                Style="{DynamicResource ButtonPrimary}"
                                Height="40"
                                HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Style="{DynamicResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Control de Fila" Style="{DynamicResource BodyText}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Button x:Name="StartQueueButton" Content="Iniciar" Style="{DynamicResource ButtonSuccess}" Height="40" Margin="0,0,0,8"/>
                        <Button x:Name="RestartQueueButton" Content="Reiniciar" Style="{DynamicResource ButtonWarning}" Height="40"/>
                        <TextBlock x:Name="AdminStatusText" Text="Estado: Detenida" Style="{DynamicResource CaptionText}" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
