<UserControl x:Class="ControlFilas2026.UserControls.AdministracionUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ControlFilas2026.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="{StaticResource BackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="15">
                <TextBlock Text="Administración" 
                           Style="{StaticResource HeaderTextStyle}"/>
                
                <!-- Control de Cajas Section -->
                <Border Style="{StaticResource SectionContainerStyle}">
                    <StackPanel>
                        <TextBlock Text="Gestión de Cajas" 
                                   Style="{StaticResource SubHeaderTextStyle}"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Select Box -->
                            <TextBlock Grid.Row="0" Grid.Column="0" 
                                       Text="Seleccionar Caja:" 
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,10,10"
                                       FontWeight="SemiBold"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" 
                                      Name="BoxComboBox"
                                      Height="38"
                                      Margin="0,0,0,10"
                                      Padding="10"
                                      FontSize="13"/>
                            
                            <!-- Enable Button -->
                            <Button Grid.Row="1" Grid.Column="0"
                                    Content="✓ Habilitar" 
                                    Style="{StaticResource ModernButtonStyle}"
                                    Background="{StaticResource SuccessBrush}"
                                    Name="EnableBoxButton"
                                    Margin="0,0,5,10"
                                    Height="38"
                                    FontWeight="Bold"/>
                            
                            <!-- Disable Button -->
                            <Button Grid.Row="1" Grid.Column="1"
                                    Content="✕ Deshabilitar" 
                                    Style="{StaticResource ModernButtonStyle}"
                                    Background="{StaticResource WarningBrush}"
                                    Name="DisableBoxButton"
                                    Margin="5,0,0,10"
                                    Height="38"
                                    FontWeight="Bold"/>
                            
                            <!-- Enable All Separator -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                       Text="Operaciones Globales" 
                                       Foreground="{StaticResource SecondaryBrush}"
                                       Margin="0,10,0,10"
                                       FontWeight="Bold"
                                       FontSize="12"/>
                            
                            <!-- Enable All Button -->
                            <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                    Content="✓✓ Habilitar Todas las Cajas" 
                                    Style="{StaticResource ModernButtonStyle}"
                                    Background="{StaticResource SuccessBrush}"
                                    Name="EnableAllButton"
                                    Height="38"
                                    FontWeight="Bold"
                                    Margin="0"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Queue Control Section -->
                <Border Style="{StaticResource SectionContainerStyle}">
                    <StackPanel>
                        <TextBlock Text="Control de Fila" 
                                   Style="{StaticResource SubHeaderTextStyle}"/>
                        
                        <StackPanel Orientation="Vertical">
                            <Button Content="▶ Iniciar Fila" 
                                    Style="{StaticResource ModernButtonStyle}"
                                    Background="{StaticResource SuccessBrush}"
                                    Name="StartQueueButton"
                                    Height="40"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Margin="0,0,0,10"/>
                            <Button Content="⟲ Reiniciar Fila" 
                                    Style="{StaticResource ModernButtonStyle}"
                                    Background="{StaticResource WarningBrush}"
                                    Name="RestartQueueButton"
                                    Height="40"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Margin="0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
