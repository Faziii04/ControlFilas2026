<UserControl x:Class="ControlFilas2026.UserControls.LoginUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ControlFilas2026.UserControls"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BrushBackground}" VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel Width="380" VerticalAlignment="Center">
            <!-- HEADER -->
            <TextBlock Text="Control de Filas" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource BrushPrimary}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="Sistema Bancario 2026" FontSize="13" Foreground="{DynamicResource BrushSecondary}" HorizontalAlignment="Center" Margin="0,0,0,24" FontWeight="Medium"/>
            
            <!-- DIVIDER -->
            <Rectangle Height="2" Fill="{DynamicResource BrushPrimary}" Width="60" HorizontalAlignment="Center" Margin="0,0,0,24"/>
            
            <!-- USERNAME -->
            <TextBlock Text="Usuario" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,6"/>
            <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,18">
                <TextBox x:Name="UsernameTextBox" Height="20" FontSize="13" Background="Transparent" BorderThickness="0"/>
            </Border>
            
            <!-- PASSWORD -->
            <TextBlock Text="Contraseña" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushText}" Margin="0,0,0,6"/>
            <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,24">
                <PasswordBox x:Name="PasswordBox" Height="20" FontSize="13" Background="Transparent" BorderThickness="0"/>
            </Border>
            
            <!-- LOGIN BUTTON -->
            <Button Content="Ingresar" Style="{StaticResource ButtonPrimary}" Height="44" FontSize="15" Name="LoginButton" Margin="0,0,0,12"/>
            
            <!-- ERROR MESSAGE -->
            <TextBlock x:Name="ErrorMessage" Foreground="{DynamicResource BrushAccent}" FontSize="12" TextWrapping="Wrap" Visibility="Collapsed" FontWeight="SemiBold" TextAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
