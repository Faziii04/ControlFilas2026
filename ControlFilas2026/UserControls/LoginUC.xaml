<UserControl x:Class="ControlFilas2026.UserControls.LoginUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ControlFilas2026.UserControls"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BrushBackground}">
        <Grid Width="520" MaxWidth="560" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Background="{DynamicResource BrushSurface}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="44"
                    Margin="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.08" Direction="270"/>
                </Border.Effect>

                <StackPanel>
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,26">
                        <Ellipse Width="78" Height="78" Fill="{DynamicResource GradientPrimary}"/>
                        <TextBlock Text="CF"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock Text="Control de Filas"
                               Style="{DynamicResource HeaderText}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Sistema Bancario"
                               Style="{DynamicResource CaptionText}"
                               HorizontalAlignment="Center"
                               FontWeight="Medium"
                               Margin="0,0,0,34"/>

                    <StackPanel Margin="0,0,0,22">
                        <TextBlock Text="Usuario"
                                   Style="{DynamicResource LabelText}"
                                   Margin="0,0,0,10"/>
                        <Border Background="{DynamicResource BrushCard}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1.5"
                                CornerRadius="10"
                                Padding="18,14"
                                Height="52">
                            <TextBox x:Name="UsernameTextBox"
                                     FontSize="14"
                                     FontWeight="Medium"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource BrushText}"
                                     VerticalAlignment="Center"
                                     Text="admin"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,28">
                        <TextBlock Text="Contraseña"
                                   Style="{DynamicResource LabelText}"
                                   Margin="0,0,0,10"/>
                        <Border Background="{DynamicResource BrushCard}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1.5"
                                CornerRadius="10"
                                Padding="18,14"
                                Height="52">
                            <PasswordBox x:Name="PasswordBox"
                                         FontSize="14"
                                         FontWeight="Medium"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{DynamicResource BrushText}"
                                         VerticalAlignment="Center"
                                         Password="123"/>
                        </Border>
                    </StackPanel>

                    <Button Content="Iniciar sesión"
                            Style="{DynamicResource ButtonPrimary}"
                            Height="52"
                            FontSize="15"
                            FontWeight="Bold"
                            Name="LoginButton"
                            Margin="0,0,0,14"/>

                    <Button Content="Cambiar tema"
                            Style="{DynamicResource ButtonAccent}"
                            Height="42"
                            FontSize="13"
                            Name="ThemeToggleButton"
                            Margin="0,0,0,14"/>

                    <Border Background="#FEF2F2"
                            BorderBrush="#FCA5A5"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14,10"
                            Margin="0,8,0,0"
                            x:Name="ErrorContainer"
                            Visibility="Collapsed">
                        <TextBlock x:Name="ErrorMessage"
                                   Foreground="#B91C1C"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
