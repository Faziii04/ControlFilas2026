<UserControl x:Class="ControlFilas2026.UserControls.LoginUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ControlFilas2026.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <Viewbox Stretch="Uniform" MaxWidth="500" MaxHeight="700">
            <Border Background="{DynamicResource SurfaceBrush}" 
                    CornerRadius="16" 
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="2"
                    Padding="60,50"
                    Width="500"
                    Margin="20">
                <StackPanel VerticalAlignment="Center">
                    <Ellipse Width="80" Height="80" 
                             Fill="{DynamicResource PrimaryBrush}"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,25"/>

                    <TextBlock Text="Control de Filas" 
                               FontSize="28" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource PrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Sistema Bancario" 
                               FontSize="14" 
                               Foreground="{DynamicResource SecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,32"
                               FontWeight="Medium"/>

                    <Rectangle Height="3" 
                               Fill="{DynamicResource PrimaryBrush}" 
                               Width="60"
                               Margin="0,0,0,32"
                               HorizontalAlignment="Center"/>


                    <TextBlock Text="Usuario" 
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,0,0,10"
                               FontWeight="SemiBold"
                               FontSize="13"/>
                    <TextBox Name="UsernameTextBox" 
                             Height="45" 
                             Padding="14,12"
                             FontSize="13"
                             Background="{DynamicResource LightGrayBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="2"
                             Margin="0,0,0,22"
                             VerticalAlignment="Center"
                             VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="8"
                                                    Background="{TemplateBinding Background}">
                                                <ScrollViewer x:Name="PART_ContentHost" 
                                                              Padding="{TemplateBinding Padding}"
                                                              VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <TextBlock Text="Contraseña" 
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0,0,0,10"
                               FontWeight="SemiBold"
                               FontSize="13"/>
                    <PasswordBox Name="PasswordBox" 
                                 Height="45" 
                                 Padding="14,12"
                                 FontSize="13"
                                 Background="{DynamicResource LightGrayBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="2"
                                 Margin="0,0,0,30"
                                 VerticalAlignment="Center"
                                 VerticalContentAlignment="Center">
                        <PasswordBox.Style>
                            <Style TargetType="PasswordBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="PasswordBox">
                                            <Border BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="8"
                                                    Background="{TemplateBinding Background}">
                                                <ScrollViewer x:Name="PART_ContentHost" 
                                                              Padding="{TemplateBinding Padding}"
                                                              VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>

                    <Button Content="Ingresar" 
                            Style="{StaticResource ModernButtonStyle}"
                            Height="50"
                            FontSize="16"
                            FontWeight="Bold"
                            Background="{DynamicResource PrimaryBrush}"
                            Name="LoginButton"
                            Margin="0,0,0,18"
                            Cursor="Hand"/>

                    <TextBlock Name="ErrorMessage"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="13"
                               Margin="0,0,0,0"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               FontWeight="SemiBold"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Viewbox>
    </Grid>
</UserControl>
