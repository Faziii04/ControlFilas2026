<UserControl x:Class="ControlFilas2026.UserControls.LoginUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ControlFilas2026.UserControls"
             mc:Ignorable="d">
    <Grid>
        <!-- BACKGROUND GRADIENT OVERLAY -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F8FAFC" Offset="0"/>
                <GradientStop Color="#E2E8F0" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <!-- MAIN LOGIN CONTAINER -->
        <Grid Width="520" MaxWidth="560" HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- GLASSMORPHISM CARD -->
            <Border Background="White"
                    CornerRadius="24"
                    Padding="48"
                    Margin="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="8" Opacity="0.15" Direction="270"/>
                </Border.Effect>
                
                <StackPanel>
                    <!-- MODERN LOGO -->
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,32">
                        <Ellipse Width="96" Height="96" Fill="{DynamicResource GradientPrimary}"/>
                        <TextBlock Text="🏦" FontSize="48" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   Effect="{x:Null}"/>
                    </Grid>
                    
                    <!-- TITLE SECTION -->
                    <TextBlock Text="Control de Filas"
                               Style="{DynamicResource HeaderText}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Sistema Bancario Digital"
                               Style="{DynamicResource CaptionText}"
                               HorizontalAlignment="Center"
                               FontWeight="Medium"
                               Margin="0,0,0,40"/>
                    
                    <!-- USERNAME INPUT -->
                    <StackPanel Margin="0,0,0,24">
                        <TextBlock Text="Nombre de Usuario"
                                   Style="{DynamicResource LabelText}"
                                   Margin="0,0,0,12"/>
                        <Border Background="{DynamicResource BrushCard}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="2"
                                CornerRadius="12"
                                Padding="20,16"
                                Height="56">
                            <TextBox x:Name="UsernameTextBox"
                                     FontSize="15"
                                     FontWeight="Medium"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource BrushText}"
                                     VerticalAlignment="Center"
                                     Text="admin"/>
                        </Border>
                    </StackPanel>
                    
                    <!-- PASSWORD INPUT -->
                    <StackPanel Margin="0,0,0,32">
                        <TextBlock Text="Contraseña"
                                   Style="{DynamicResource LabelText}"
                                   Margin="0,0,0,12"/>
                        <Border Background="{DynamicResource BrushCard}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="2"
                                CornerRadius="12"
                                Padding="20,16"
                                Height="56">
                            <PasswordBox x:Name="PasswordBox"
                                         FontSize="15"
                                         FontWeight="Medium"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{DynamicResource BrushText}"
                                         VerticalAlignment="Center"
                                         Password="123"/>
                        </Border>
                    </StackPanel>
                    
                    <!-- LOGIN BUTTON -->
                    <Button Content="🔐 Iniciar Sesión"
                            Style="{DynamicResource ButtonPrimary}"
                            Height="56"
                            FontSize="16"
                            FontWeight="Bold"
                            Name="LoginButton"
                            Margin="0,0,0,20"/>
                    
                    <!-- THEME TOGGLE -->
                    <Button Content="🎨 Cambiar Tema"
                            Style="{DynamicResource ButtonAccent}"
                            Height="44"
                            FontSize="13"
                            Name="ThemeToggleButton"
                            Margin="0,0,0,16"/>
                    
                    <!-- ERROR MESSAGE -->
                    <Border Background="#FEF2F2"
                            BorderBrush="#FCA5A5"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16,12"
                            Margin="0,8,0,0"
                            x:Name="ErrorContainer"
                            Visibility="Collapsed">
                        <TextBlock x:Name="ErrorMessage"
                                   Foreground="#DC2626"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
