<UserControl x:Class="ControlFilas2026.UserControls.ClienteUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ControlFilas2026.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="{DynamicResource BackgroundBrush}">
        <StackPanel Margin="15">
            <TextBlock Text="Panel de Clientes" 
                       Style="{StaticResource HeaderTextStyle}"/>
            
            <Border Style="{StaticResource SectionContainerStyle}">
                <StackPanel>
                    <TextBlock Text="Llamadas Activas" 
                               Style="{StaticResource SubHeaderTextStyle}"/>
                    
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="220">
                        <ItemsControl Name="CallsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource LightGrayBrush}"
                                            CornerRadius="6"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <Border Grid.Column="0"
                                                    Background="{DynamicResource SecondaryBrush}"
                                                    CornerRadius="4"
                                                    Padding="10"
                                                    Margin="0,0,12,0">
                                                <TextBlock Text="Caja 1" 
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="Cliente: 042" 
                                                           Foreground="{DynamicResource TextBrush}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13"/>
                                                <TextBlock Text="Estado: Siendo atendido" 
                                                           Foreground="{DynamicResource WarningBrush}"
                                                           FontSize="11"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                            
                                            <TextBlock Grid.Column="2"
                                                       Text="2:34" 
                                                       Foreground="{DynamicResource BorderBrush}"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       FontStyle="Italic"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
            
            <Border Style="{StaticResource SectionContainerStyle}">
                <StackPanel>
                    <TextBlock Text="Obtener Turno" 
                               Style="{StaticResource SubHeaderTextStyle}"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Row="0" Grid.Column="0"
                                Content="Tomar Numero" 
                                Style="{StaticResource ModernButtonStyle}"
                                Background="{DynamicResource SuccessBrush}"
                                Name="GetTicketButton"
                                Width="150"
                                Height="50"
                                FontSize="13"
                                FontWeight="Bold"
                                Margin="0,0,0,10"/>

                        <Button Grid.Row="1" Grid.Column="0"
                                Content="Turno Prioritario" 
                                Style="{StaticResource ModernButtonStyle}"
                                Background="{DynamicResource WarningBrush}"
                                Name="GetElderlyTicketButton"
                                Width="150"
                                Height="50"
                                FontSize="13"
                                FontWeight="Bold"
                                Margin="0"
                                ToolTip="Para personas mayores, embarazadas o con discapacidad"/>

                        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                Background="{DynamicResource SecondaryBrush}"
                                CornerRadius="6"
                                Padding="20"
                                Margin="15,0,0,0">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Tu Turno" 
                                           Foreground="White"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,5"/>
                                <TextBlock Name="TicketNumberDisplay"
                                           Text="--" 
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionContainerStyle}" Margin="10,5,10,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Posicion en Fila" 
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="5" 
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource SecondaryBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Tiempo Estimado" 
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="~15 min" 
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource SuccessBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
