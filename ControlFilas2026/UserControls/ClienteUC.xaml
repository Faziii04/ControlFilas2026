<UserControl x:Class="ControlFilas2026.UserControls.ClienteUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ControlFilas2026.UserControls"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BrushBackground}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <TextBlock Text="Cliente" Style="{DynamicResource SubHeaderText}" Margin="0,0,0,16"/>

                <Border Style="{DynamicResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Llamadas" Style="{DynamicResource BodyText}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <ListBox x:Name="CallsListBox" Height="180" Background="{DynamicResource BrushCard}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"/>
                    </StackPanel>
                </Border>

                <Border Style="{DynamicResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Obtener Turno" Style="{DynamicResource BodyText}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="GetTicketButton" Grid.Column="0" Content="Normal" Style="{DynamicResource ButtonSuccess}" Height="44" Margin="0,0,6,0"/>
                            <Button x:Name="GetSpecialTicketButton" Grid.Column="1" Content="Especial" Style="{DynamicResource ButtonAccent}" Height="44" Margin="6,0,0,0"/>
                        </Grid>
                        <Border Background="{DynamicResource BrushPrimary}" CornerRadius="10" Margin="0,14,0,0" Padding="14">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="Último Turno" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TicketNumberDisplay" Text="--" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{DynamicResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Tickets recientes (posición)" Style="{DynamicResource BodyText}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <ListBox x:Name="RecentTicketsListBox" Height="120" Background="{DynamicResource BrushCard}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"/>
                    </StackPanel>
                </Border>

                <Border Style="{DynamicResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Personas en espera" Style="{DynamicResource CaptionText}"/>
                        <TextBlock x:Name="QueuePositionText" Text="0" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource BrushSecondary}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
