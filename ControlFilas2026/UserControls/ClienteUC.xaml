<UserControl x:Class="ControlFilas2026.UserControls.ClienteUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ControlFilas2026.UserControls"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BrushBackground}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <TextBlock Text="Panel de Clientes" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrushPrimary}" Margin="0,0,0,16"/>
                
                <!-- CALLS SECTION -->
                <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Llamadas Activas" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource BrushPrimary}" Margin="0,0,0,12"/>
                        
                        <ScrollViewer Height="150" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Background="{DynamicResource BrushBackground}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="{DynamicResource BrushPrimary}" CornerRadius="4" Padding="8" Margin="0,0,12,0">
                                            <TextBlock Text="Caja 1" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Cliente: 042" Foreground="{DynamicResource BrushText}" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="Siendo atendido" Foreground="{DynamicResource BrushWarning}" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="2:34" Foreground="{DynamicResource BrushTextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
                
                <!-- TICKET SECTION -->
                <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Obtener Turno" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource BrushPrimary}" Margin="0,0,0,12"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Tomar Número" Style="{DynamicResource ButtonSuccess}" Height="48" Width="140" FontSize="13" Name="GetTicketButton"/>
                            <Border Grid.Column="1" Background="{DynamicResource BrushPrimary}" CornerRadius="8" Margin="12,0,0,0">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="Tu Turno" Foreground="White" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="TicketNumberDisplay" Text="--" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- QUEUE INFO -->
                <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Posición" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" FontWeight="SemiBold"/>
                            <TextBlock Text="5" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource BrushSecondary}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Tiempo Est." FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" FontWeight="SemiBold"/>
                            <TextBlock Text="~15 min" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource BrushSuccess}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
