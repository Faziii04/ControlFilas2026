<UserControl x:Class="ControlFilas2026.UserControls.CajasUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ControlFilas2026.UserControls"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BrushBackground}">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Cajas"
                       Style="{DynamicResource SubHeaderText}"
                       Margin="0,0,0,12"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <UniformGrid Columns="2" Rows="4">
                    <Border Style="{DynamicResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Caja 1" Style="{DynamicResource BodyText}" FontWeight="Bold"/>
                            <TextBlock x:Name="Box1StatusText" Text="Disponible" Foreground="{DynamicResource BrushSuccess}" Margin="0,4,0,0"/>
                            <TextBlock x:Name="Box1CurrentText" Text="Sin cliente" Style="{DynamicResource CaptionText}" Margin="0,2,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Button x:Name="CallBox1Button" Grid.Column="0" Content="Llamar" Style="{DynamicResource ButtonPrimary}" Margin="0,0,4,0"/>
                                <Button x:Name="FreeBox1Button" Grid.Column="1" Content="Liberar" Style="{DynamicResource ButtonWarning}" Margin="4,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Caja 2" Style="{DynamicResource BodyText}" FontWeight="Bold"/>
                            <TextBlock x:Name="Box2StatusText" Text="Disponible" Foreground="{DynamicResource BrushSuccess}" Margin="0,4,0,0"/>
                            <TextBlock x:Name="Box2CurrentText" Text="Sin cliente" Style="{DynamicResource CaptionText}" Margin="0,2,0,8"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Button x:Name="CallBox2Button" Grid.Column="0" Content="Llamar" Style="{DynamicResource ButtonPrimary}" Margin="0,0,4,0"/>
                                <Button x:Name="FreeBox2Button" Grid.Column="1" Content="Liberar" Style="{DynamicResource ButtonWarning}" Margin="4,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Caja 3" Style="{DynamicResource BodyText}" FontWeight="Bold"/>
                            <TextBlock x:Name="Box3StatusText" Text="Disponible" Foreground="{DynamicResource BrushSuccess}" Margin="0,4,0,0"/>
                            <TextBlock x:Name="Box3CurrentText" Text="Sin cliente" Style="{DynamicResource CaptionText}" Margin="0,2,0,8"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Button x:Name="CallBox3Button" Grid.Column="0" Content="Llamar" Style="{DynamicResource ButtonPrimary}" Margin="0,0,4,0"/>
                                <Button x:Name="FreeBox3Button" Grid.Column="1" Content="Liberar" Style="{DynamicResource ButtonWarning}" Margin="4,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Caja 4" Style="{DynamicResource BodyText}" FontWeight="Bold"/>
                            <TextBlock x:Name="Box4StatusText" Text="Disponible" Foreground="{DynamicResource BrushSuccess}" Margin="0,4,0,0"/>
                            <TextBlock x:Name="Box4CurrentText" Text="Sin cliente" Style="{DynamicResource CaptionText}" Margin="0,2,0,8"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Button x:Name="CallBox4Button" Grid.Column="0" Content="Llamar" Style="{DynamicResource ButtonPrimary}" Margin="0,0,4,0"/>
                                <Button x:Name="FreeBox4Button" Grid.Column="1" Content="Liberar" Style="{DynamicResource ButtonWarning}" Margin="4,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Caja 5" Style="{DynamicResource BodyText}" FontWeight="Bold"/>
                            <TextBlock x:Name="Box5StatusText" Text="Disponible" Foreground="{DynamicResource BrushSuccess}" Margin="0,4,0,0"/>
                            <TextBlock x:Name="Box5CurrentText" Text="Sin cliente" Style="{DynamicResource CaptionText}" Margin="0,2,0,8"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Button x:Name="CallBox5Button" Grid.Column="0" Content="Llamar" Style="{DynamicResource ButtonPrimary}" Margin="0,0,4,0"/>
                                <Button x:Name="FreeBox5Button" Grid.Column="1" Content="Liberar" Style="{DynamicResource ButtonWarning}" Margin="4,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Caja 6" Style="{DynamicResource BodyText}" FontWeight="Bold"/>
                            <TextBlock x:Name="Box6StatusText" Text="Disponible" Foreground="{DynamicResource BrushSuccess}" Margin="0,4,0,0"/>
                            <TextBlock x:Name="Box6CurrentText" Text="Sin cliente" Style="{DynamicResource CaptionText}" Margin="0,2,0,8"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Button x:Name="CallBox6Button" Grid.Column="0" Content="Llamar" Style="{DynamicResource ButtonPrimary}" Margin="0,0,4,0"/>
                                <Button x:Name="FreeBox6Button" Grid.Column="1" Content="Liberar" Style="{DynamicResource ButtonWarning}" Margin="4,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Caja 7" Style="{DynamicResource BodyText}" FontWeight="Bold"/>
                            <TextBlock x:Name="Box7StatusText" Text="Disponible" Foreground="{DynamicResource BrushSuccess}" Margin="0,4,0,0"/>
                            <TextBlock x:Name="Box7CurrentText" Text="Sin cliente" Style="{DynamicResource CaptionText}" Margin="0,2,0,8"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Button x:Name="CallBox7Button" Grid.Column="0" Content="Llamar" Style="{DynamicResource ButtonPrimary}" Margin="0,0,4,0"/>
                                <Button x:Name="FreeBox7Button" Grid.Column="1" Content="Liberar" Style="{DynamicResource ButtonWarning}" Margin="4,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
