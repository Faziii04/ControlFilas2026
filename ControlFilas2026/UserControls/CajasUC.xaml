<UserControl x:Class="ControlFilas2026.UserControls.CajasUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ControlFilas2026.UserControls"
             mc:Ignorable="d">
    <Grid Background="{DynamicResource BrushBackground}">
        <StackPanel Margin="16">
            <TextBlock Text="Estado de Cajas" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrushPrimary}" Margin="0,0,0,16"/>
            
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <WrapPanel>
                    <!-- BOX 1 -->
                    <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="8" Width="120" Height="140">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Caja 1" FontSize="12" Foreground="{DynamicResource BrushText}" HorizontalAlignment="Center" Margin="0,0,0,10" FontWeight="SemiBold"/>
                            <Border Background="{DynamicResource BrushSuccess}" CornerRadius="35" Width="50" Height="50" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <TextBlock Text="✓" FontSize="28" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Disponible" FontSize="11" Foreground="{DynamicResource BrushSuccess}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- BOX 2 -->
                    <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="8" Width="120" Height="140">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Caja 2" FontSize="12" Foreground="{DynamicResource BrushText}" HorizontalAlignment="Center" Margin="0,0,0,10" FontWeight="SemiBold"/>
                            <Border Background="{DynamicResource BrushSuccess}" CornerRadius="35" Width="50" Height="50" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <TextBlock Text="✓" FontSize="28" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Disponible" FontSize="11" Foreground="{DynamicResource BrushSuccess}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- BOX 3 -->
                    <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="8" Width="120" Height="140">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Caja 3" FontSize="12" Foreground="{DynamicResource BrushText}" HorizontalAlignment="Center" Margin="0,0,0,10" FontWeight="SemiBold"/>
                            <Border Background="{DynamicResource BrushWarning}" CornerRadius="35" Width="50" Height="50" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <TextBlock Text="⏳" FontSize="28" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Ocupada" FontSize="11" Foreground="{DynamicResource BrushWarning}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- BOX 4 -->
                    <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="8" Width="120" Height="140">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Caja 4" FontSize="12" Foreground="{DynamicResource BrushText}" HorizontalAlignment="Center" Margin="0,0,0,10" FontWeight="SemiBold"/>
                            <Border Background="{DynamicResource BrushSuccess}" CornerRadius="35" Width="50" Height="50" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <TextBlock Text="✓" FontSize="28" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Disponible" FontSize="11" Foreground="{DynamicResource BrushSuccess}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- BOX 5 -->
                    <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="8" Width="120" Height="140">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Caja 5" FontSize="12" Foreground="{DynamicResource BrushText}" HorizontalAlignment="Center" Margin="0,0,0,10" FontWeight="SemiBold"/>
                            <Border Background="{DynamicResource BrushSuccess}" CornerRadius="35" Width="50" Height="50" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <TextBlock Text="✓" FontSize="28" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Disponible" FontSize="11" Foreground="{DynamicResource BrushSuccess}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- BOX 6 -->
                    <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="8" Width="120" Height="140">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Caja 6" FontSize="12" Foreground="{DynamicResource BrushText}" HorizontalAlignment="Center" Margin="0,0,0,10" FontWeight="SemiBold"/>
                            <Border Background="{DynamicResource BrushAccent}" CornerRadius="35" Width="50" Height="50" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <TextBlock Text="✕" FontSize="28" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Deshabilitada" FontSize="11" Foreground="{DynamicResource BrushAccent}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- BOX 7 -->
                    <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="8" Width="120" Height="140">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Caja 7" FontSize="12" Foreground="{DynamicResource BrushText}" HorizontalAlignment="Center" Margin="0,0,0,10" FontWeight="SemiBold"/>
                            <Border Background="{DynamicResource BrushSuccess}" CornerRadius="35" Width="50" Height="50" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <TextBlock Text="✓" FontSize="28" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Disponible" FontSize="11" Foreground="{DynamicResource BrushSuccess}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</UserControl>
