<Window x:Class="ControlFilas2026.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ControlFilas2026"
        xmlns:uc="clr-namespace:ControlFilas2026.UserControls"
        mc:Ignorable="d"
        Title="Control de Filas 2026 - Banco" 
        WindowState="Maximized"
        Background="{DynamicResource BrushBackground}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        
        <Grid Grid.Row="0" x:Name="ContentGrid" Background="{DynamicResource BrushBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Background="{DynamicResource BrushBackground}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="0,0,1,0">
                <uc:AdministracionUC x:Name="AdminControl" Visibility="Collapsed"/>
            </Border>
            
            <Border Grid.Column="1" Background="{DynamicResource BrushBackground}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1,0,1,0">
                <Grid x:Name="MiddleContent">
                    <uc:LoginUC x:Name="LoginControl"/>
                    <uc:CajasUC x:Name="CajasControl" Visibility="Collapsed"/>
                </Grid>
            </Border>
            
            <Border Grid.Column="2" Background="{DynamicResource BrushBackground}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1,0,0,0">
                <uc:ClienteUC x:Name="ClienteControl" Visibility="Collapsed"/>
            </Border>
        </Grid>
        
        <uc:AbajoUC Grid.Row="1" Background="{DynamicResource BrushPrimary}"/>
    </Grid>
</Window>
