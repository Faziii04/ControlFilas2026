<Window x:Class="ControlFilas2026.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:ControlFilas2026"
    xmlns:uc="clr-namespace:ControlFilas2026.UserControls"
    mc:Ignorable="d"
    Title="Control de Filas 2026 - Banco" 
    WindowState="Maximized"
    Background="{StaticResource BackgroundBrush}"
    WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>
        
        <!-- Main Content Area - 3 Column Layout -->
        <Grid Grid.Row="0" x:Name="ContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Column: Administración UC -->
            <Border Grid.Column="0" 
                    Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="0,0,1,0">
                <uc:AdministracionUC x:Name="AdminControl" 
                                     Visibility="Collapsed"/>
            </Border>
            
            
            <!-- Middle Column: Login or Cajas UC -->
            <Border Grid.Column="1" 
                    Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="1,0,1,0">
                <Grid x:Name="MiddleContent">
                    <!-- Login UC - Initially Visible -->
                    <uc:LoginUC x:Name="LoginControl" 
                                HorizontalAlignment="Stretch" 
                                VerticalAlignment="Stretch"/>
                    
                    <!-- Cajas UC - Initially Hidden -->
                    <uc:CajasUC x:Name="CajasControl" 
                                Visibility="Collapsed"/>
                </Grid>
            </Border>
            
            
            <!-- Right Column: Cliente UC -->
            <Border Grid.Column="2" 
                    Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="1,0,0,0">
                <uc:ClienteUC x:Name="ClienteControl" 
                              Visibility="Collapsed"/>
            </Border>
        </Grid>
        
        <!-- Footer / Bottom Area -->
        <uc:AbajoUC Grid.Row="1"/>
    </Grid>
</Window>
