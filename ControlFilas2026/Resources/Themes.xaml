<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- MODERN GRADIENT THEME COLORS -->
    <Color x:Key="ColorPrimary">#6366F1</Color>
    <Color x:Key="ColorPrimaryLight">#818CF8</Color>
    <Color x:Key="ColorPrimaryDark">#4F46E5</Color>
    <Color x:Key="ColorSecondary">#10B981</Color>
    <Color x:Key="ColorAccent">#F59E0B</Color>
    <Color x:Key="ColorSuccess">#22C55E</Color>
    <Color x:Key="ColorWarning">#F97316</Color>
    <Color x:Key="ColorError">#EF4444</Color>
    
    <!-- SURFACE COLORS -->
    <Color x:Key="ColorBackground">#F8FAFC</Color>
    <Color x:Key="ColorSurface">#FFFFFF</Color>
    <Color x:Key="ColorCard">#F1F5F9</Color>
    <Color x:Key="ColorOverlay">#1E293B</Color>
    
    <!-- TEXT COLORS -->
    <Color x:Key="ColorText">#0F172A</Color>
    <Color x:Key="ColorTextSecondary">#64748B</Color>
    <Color x:Key="ColorTextLight">#94A3B8</Color>
    
    <!-- BORDER COLORS -->
    <Color x:Key="ColorBorder">#E2E8F0</Color>
    <Color x:Key="ColorDivider">#F1F5F9</Color>
    
    <!-- BRUSHES -->
    <SolidColorBrush x:Key="BrushPrimary" Color="{DynamicResource ColorPrimary}"/>
    <SolidColorBrush x:Key="BrushPrimaryLight" Color="{DynamicResource ColorPrimaryLight}"/>
    <SolidColorBrush x:Key="BrushPrimaryDark" Color="{DynamicResource ColorPrimaryDark}"/>
    <SolidColorBrush x:Key="BrushSecondary" Color="{DynamicResource ColorSecondary}"/>
    <SolidColorBrush x:Key="BrushAccent" Color="{DynamicResource ColorAccent}"/>
    <SolidColorBrush x:Key="BrushSuccess" Color="{DynamicResource ColorSuccess}"/>
    <SolidColorBrush x:Key="BrushWarning" Color="{DynamicResource ColorWarning}"/>
    <SolidColorBrush x:Key="BrushError" Color="{DynamicResource ColorError}"/>
    <SolidColorBrush x:Key="BrushBackground" Color="{DynamicResource ColorBackground}"/>
    <SolidColorBrush x:Key="BrushSurface" Color="{DynamicResource ColorSurface}"/>
    <SolidColorBrush x:Key="BrushCard" Color="{DynamicResource ColorCard}"/>
    <SolidColorBrush x:Key="BrushOverlay" Color="{DynamicResource ColorOverlay}"/>
    <SolidColorBrush x:Key="BrushText" Color="{DynamicResource ColorText}"/>
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{DynamicResource ColorTextSecondary}"/>
    <SolidColorBrush x:Key="BrushTextLight" Color="{DynamicResource ColorTextLight}"/>
    <SolidColorBrush x:Key="BrushBorder" Color="{DynamicResource ColorBorder}"/>
    <SolidColorBrush x:Key="BrushDivider" Color="{DynamicResource ColorDivider}"/>

    <!-- GRADIENTS -->
    <LinearGradientBrush x:Key="GradientPrimary" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#6366F1" Offset="0"/>
        <GradientStop Color="#8B5CF6" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="GradientSuccess" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#10B981" Offset="0"/>
        <GradientStop Color="#22C55E" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="GradientWarning" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F59E0B" Offset="0"/>
        <GradientStop Color="#F97316" Offset="1"/>
    </LinearGradientBrush>

    <!-- MODERN BUTTON STYLES -->
    <Style x:Key="ButtonPrimary" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource GradientPrimary}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                            CornerRadius="10" 
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.2" Direction="270"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"
                                        TextBlock.Foreground="White"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource BrushPrimaryLight}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource BrushPrimaryDark}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ButtonSuccess" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource GradientSuccess}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                            CornerRadius="10" 
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.2" Direction="270"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"
                                        TextBlock.Foreground="White"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#16A085"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ButtonWarning" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource GradientWarning}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                            CornerRadius="10" 
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.2" Direction="270"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"
                                        TextBlock.Foreground="White"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#D68910"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ButtonAccent" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource BrushOverlay}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                            CornerRadius="8" 
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"
                                        TextBlock.Foreground="White"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#374151"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- CARD STYLE -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource BrushSurface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="Margin" Value="8"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="12" ShadowDepth="4" Opacity="0.1" Direction="270"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TEXT STYLES -->
    <Style x:Key="HeaderText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
    </Style>

    <Style x:Key="SubHeaderText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
    </Style>

    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
    </Style>

    <Style x:Key="CaptionText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}"/>
    </Style>

    <Style x:Key="LabelText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
    </Style>

</ResourceDictionary>
